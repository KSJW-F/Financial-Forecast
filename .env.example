# 数据库配置（默认 SQLite，生产环境可改为 MySQL）

DATABASE_URL=sqlite:///./financial_forecast.db



# 数据目录

DATA_DIR=./data



# AI 分析（默认启用文华接口）
# 分层：强规则 → LLM → 图表启发式
# LLM_ONLY_UNKNOWN=true：仅在规则无明确观点时调 LLM（推荐）

LLM_ENABLED=true

LLM_PROVIDER=wenhua

LLM_ONLY_UNKNOWN=true

LLM_TIMEOUT=120

LLM_MAX_CONTENT_CHARS=4000
LLM_RETRY_COUNT=3
LLM_RETRY_DELAY=1.5
LLM_REQUEST_DELAY=0.3
WENHUA_AI_URL=https://swarm.wenhua.com.cn/aiservice/api/ShiXi/GetContent



# 可选：OpenAI 兼容接口

# LLM_PROVIDER=openai

# OPENAI_API_KEY=

# OPENAI_BASE_URL=https://api.openai.com/v1

# OPENAI_MODEL=gpt-4o-mini



# Flask

FLASK_SECRET_KEY=change-me-in-production

FLASK_DEBUG=true

